# Streamlit / app mode
PAYDAY_APP_ENV=development
PAYDAY_DATABASE_PATH=data/payday.db
# Default behavior when PAYDAY_USE_SAMPLE_MODE is absent is sample mode (`true`).
PAYDAY_USE_SAMPLE_MODE=true
PAYDAY_ENABLE_UPLOADS=true
PAYDAY_ENABLE_DASHBOARD=true
PAYDAY_ENABLE_ANALYSIS=true
PAYDAY_SQLITE_PATH=data/payday.db
PAYDAY_DB_BACKEND=sqlite

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=payday-assets

# LLM provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=your-llm-api-key

# Transcription provider
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_API_KEY=your-transcription-api-key
TRANSCRIPTION_TIMEOUT_SECONDS=60
